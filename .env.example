# ═══════════════════════════════════════════════════════════════════════
# E-Commerce Operations Assistant — Environment Variables
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the required values.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════

# ── LLM API (OpenAI-compatible — required) ─────────────────────────────
DIAL_API_KEY=your-api-key-here
DIAL_ENDPOINT=https://your-openai-endpoint.example.com
DIAL_API_VERSION=2023-12-01-preview
DIAL_DEPLOYMENT=gpt-4.1-mini-2025-04-14

# ── Application database ───────────────────────────────────────────────
APP_POSTGRES_PASSWORD=postgres

# ── MCP tool routing ───────────────────────────────────────────────────
# "none" = inline tools only | "sales" | "sales,inventory" | "all"
USE_MCP_TOOLS=all

# ── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Langfuse observability ─────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-local
LANGFUSE_SECRET_KEY=sk-lf-local
LANGFUSE_POSTGRES_PASSWORD=CHANGE_ME
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME
LANGFUSE_SALT=CHANGE_ME
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME
LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME

# ── Langfuse infra ─────────────────────────────────────────────────────
CLICKHOUSE_PASSWORD=CHANGE_ME
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=CHANGE_ME
